diff --git a/src/manette-backend.c b/src/manette-backend.c
index 291da5d..fe408dd 100644
--- a/src/manette-backend.c
+++ b/src/manette-backend.c
@@ -179,8 +179,8 @@ void
 manette_backend_emit_event (ManetteBackend *self,
                             ManetteEvent   *event)
 {
-  g_assert (MANETTE_IS_BACKEND (self));
-  g_assert (event != NULL);
+  if (!MANETTE_IS_BACKEND (self) || event == NULL)
